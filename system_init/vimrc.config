" 使用该配置时，将其放到用户根目录下并重命名为 .vimrc
set encoding=utf-8
set termencoding=utf-8
set fileencodings=utf-8,ucs-bom,gb18030,gbk,gb2312,cp936

" 为.sh和.bash文件自动添加标准化头部注释（关键修改：*.{sh,bash}）
autocmd BufNewFile *.{sh,bash} call SetShellScriptHeader()

function! SetShellScriptHeader()
    " 1. 插入脚本解释器（bash）
    call setline(1, "#!/bin/bash")
    call append(1, "#")
    call append(2, "#********************************************************************")
    
    " 2. 插入固定信息（作者、邮箱）
    call append(3, "#Author:           YiLing Wu (hj)")
    call append(4, "#email:            huangjing510@126.com")
    
    " 3. 插入动态信息（日期、文件名）
    call append(5, "#Date:             " . strftime("%Y-%m-%d %H:%M:%S"))  " 自动获取当前系统日期和精确时间
    call append(6, "#FileName:         " . expand("%:t"))         " 自动获取当前文件名（含后缀）
    
    " 4. 插入固定的URL和版权信息
    call append(7, "#URL:              https://script.huangjingblog.cn")
    call append(8, "#Description:      ")                          " 留空，方便手动填写
    call append(9, "#Copyright (C):    " . strftime("%Y") . " All rights reserved")
    call append(10, "#********************************************************************")
    
    " 5. 光标定位到Description行，方便填写描述
    call cursor(9, 20)  " 第9行（Description行）、第20列（冒号后）
    
endfunction

" 可选：同时为.sh和.bash文件设置语法高亮和缩进
autocmd FileType sh setlocal expandtab tabstop=4 shiftwidth=4 softtabstop=4 syntax=sh
autocmd BufNewFile,BufRead *.bash set filetype=sh  " 让.bash文件识别为sh类型，启用语法高亮
